# Auto-detect text files and normalize line endings to LF on commit
* text=auto eol=lf

# C/C++ source files
*.c     text eol=lf
*.h     text eol=lf
*.cpp   text eol=lf
*.hpp   text eol=lf

# CMake
CMakeLists.txt  text eol=lf
*.cmake         text eol=lf

# Scripts
*.sh    text eol=lf
*.bash  text eol=lf
*.py    text eol=lf

# Configuration
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.ini   text eol=lf
*.cfg   text eol=lf
*.conf  text eol=lf

# Documentation
*.md    text eol=lf
*.txt   text eol=lf
*.rst   text eol=lf

# Binary files — do not modify
*.bin   binary
*.elf   binary
*.hex   binary
*.axf   binary
*.srec  binary
*.lib   binary
*.a     binary
*.o     binary
*.png   binary
*.jpg   binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.tar   binary
*.gz    binary
